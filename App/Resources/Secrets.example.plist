<?xml version="1.0" encoding="UTF-8"?>
<!--
  Secrets.example.plist — 외부 API 키 템플릿 (이 파일은 커밋됨, 실제 키 X)

  사용법:
  1) 이 파일을 같은 폴더에 Secrets.plist 로 복사한다 (Secrets.plist 는 .gitignore 처리됨)
  2) 각 키에 발급받은 값을 채운다 (빈 값이면 해당 기능은 자동으로 샘플 데이터로 동작)
  3) `xcodegen generate` 후 빌드 → 키가 채워진 기능만 실데이터로 전환

  키 발급처:
  - KAKAO_REST_API_KEY   : developers.kakao.com (REST API 키)
  - HIRA_API_KEY         : data.go.kr 건강보험심사평가원 병원/약국 (Decoding 키 권장)
  - BOKJIRO_API_KEY      : data.go.kr 복지로 정부지원금 (Decoding 키 권장)
  - KDCA_VACCINE_API_KEY : data.go.kr 질병관리청 예방접종도우미 (Decoding 키 권장)
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>KAKAO_REST_API_KEY</key>
    <string></string>
    <key>HIRA_API_KEY</key>
    <string></string>
    <key>BOKJIRO_API_KEY</key>
    <string></string>
    <key>KDCA_VACCINE_API_KEY</key>
    <string></string>
</dict>
</plist>
